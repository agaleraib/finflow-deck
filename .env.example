# FinFlow Environment Configuration
# Copy this to .env and fill in your values

# Required — Claude API for agent reasoning
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — Finnhub for live news (free tier: https://finnhub.io/)
# If not set, demo headlines will be used
FINNHUB_API_KEY=your-finnhub-key

# Optional — Telegram for HITL approvals
# If not set, HITL checkpoints auto-approve after 2s
# Create a bot: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
